[Unit]
Description=AI Trader Pro v7.0
After=network.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__DIR__
Environment=PATH=__DIR__/venv/bin:/usr/bin:/bin
ExecStart=__DIR__/venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
